# Copy this file outside the repository, fill in real secrets, and reference it
# from config/kiln.local-opencode.example.toml.

# Required for private repositories and for posting the OpenCode result comment.
# A fine-grained token should have read access to contents and write access to
# pull request or issue comments for the target test repository.
GITHUB_TOKEN=github_pat_replace_me

# Required by OpenCode for the model used in /agent:<agent>:<model> commands.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Used when a /agent command omits the model segment.
OPENCODE_MODEL=anthropic/claude-sonnet-4-5

# Local mode starts with an empty environment, so include executable paths.
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
HOME=/Users/<user>
KILN_WORK_ROOT=/tmp/kiln-opencode-runs
